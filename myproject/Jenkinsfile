pipeline {
    agent any

    stages {

        stage('Build') {
            steps {
                dir('myproject') {
                    bat 'mvn clean package'
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir('myproject') {
                    bat 'docker build -t myproject:v1 .'
                }
            }
        }
        stage('Docker Push') {
           steps {
               dir('myproject') {
                  bat 'docker tag myproject:v1 megha3/myproject:v1'
                  bat 'docker push megha3/myproject:v1'
                }
            }
        }
    }
}
