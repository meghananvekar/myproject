pipeline {
    agent any

    stages {

        stage('Build') {
            steps {
                dir('myproject') {
                    bat 'mvn clean package'
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir('myproject') {
                    bat 'docker build -t megha3/myproject:%BUILD_NUMBER% .'
                }
            }
        }

        stage('Docker Push') {
            steps {
                bat 'docker push megha3/myproject:%BUILD_NUMBER%'
            }
        }
    }
}
